# Sử dụng Local Model (Miễn phí, không giới hạn rate limit)
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# (Hoặc) Sử dụng OpenAI API
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=your_api_key_here
# Lưu ý: Nếu sử dụng OpenAI API, bạn cần đăng ký tài khoản và lấy API key từ https://platform.openai.com/account/api-keys